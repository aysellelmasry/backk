# ── Backend Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in the values
# On Render/Railway/Heroku, set these as environment variables in the dashboard

# URL(s) allowed to call the API (comma-separated). Use * to allow all origins.
# Example: https://myapp.vercel.app,https://myapp.netlify.app
ALLOWED_ORIGINS=*

# Face match tolerance (lower = stricter). Range: 0.4 – 0.65
TOLERANCE=0.52

# Max file upload size in MB
MAX_UPLOAD_MB=16

# Path to your data files (default: same folder as app.py)
# DATA_DIR=/path/to/data

# File names (inside DATA_DIR)
ENCODINGS_FILE=face_encodings.pkl
METADATA_FILE=photos_metadata.pkl
GDRIVE_FILE=gdrive_file_mapping.json

# Server port (set automatically by Render/Railway)
PORT=5000

# Enable debug mode (never true in production!)
FLASK_DEBUG=false
